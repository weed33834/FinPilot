# ============================================================
# FinPilot AI 环境变量示例
# ============================================================
# 复制为 .env 并按需修改。所有变量均为可选——不设置时使用代码内默认值。
# 后端读取优先级：数据库配置 > 环境变量 > 代码内默认值。
# ------------------------------------------------------------

# ---- 管理员账号 ----
# 首次启动自动创建的默认管理员账号。建议生产环境务必覆盖密码。
FINPILOT_ADMIN_EMAIL=admin@finpilot.ai
FINPILOT_ADMIN_PASSWORD=admin123
# 管理员邮箱白名单（逗号分隔），多个管理员时设置
FINPILOT_ADMIN_EMAILS=admin@finpilot.ai

# ---- LLM 供应商（环境变量回退；推荐在管理后台 → LLM 供应商页面维护） ----
# OpenAI 兼容
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# MoonWeaver（OpenAI 兼容协议，base_url=https://api.587.lol/v1）
# 在管理后台 → LLM 供应商页面创建：
#   name=MoonWeaver, provider_type=openai, base_url=https://api.587.lol/v1
#   api_key=any, is_default=true
#   models: moonweaver-4.8（目前 API 仅有此一个模型，可同时挂到 high/low tier）

# ---- LLM 演示模式降级 ----
# 当 LLM 配置不可用时，是否启用演示降级（返回占位文本，不报错）。
# 取值：1/true/yes/on 启用；其他禁用。
FINPILOT_LLM_DEMO_FALLBACK=

# ---- 智能体检查点后端 ----
# ReAct 智能体状态持久化后端。
#   memory  —— 进程内 MemorySaver（默认，重启丢失会话）
#   sqlite  —— 落盘 SQLite 持久化（重启不丢会话）
FINPILOT_CHECKPOINT_BACKEND=memory

# ---- GitHub OAuth（可选，第三方登录） ----
# 在 GitHub OAuth App 中将回调 URL 配置为：
#   http://localhost:8001/auth/github/callback（开发）
#   https://your-domain/auth/github/callback（生产）
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=http://localhost:8001/auth/github/callback

# ---- 数据库 ----
# 默认使用 SQLite（finpilot.db），文件位于工作目录。
# 生产可替换为 PostgreSQL / MySQL，需在 finpilot/database/session.py 中调整连接字符串。
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/finpilot
